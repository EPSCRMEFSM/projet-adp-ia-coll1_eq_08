# Copy to .env.local for local dev, or set these in your host (e.g. Vercel).

# Same-origin API (leave blank).
NEXT_PUBLIC_API_BASE=

# Auth — long random string.
JWT_SECRET=change-me

# 32+ char random string — encrypts teachers' Anthropic API keys at rest.
APP_ENCRYPTION_KEY=change-me-32-chars-minimum

# Database (libSQL / Turso).
#   Local dev: leave BOTH unset → uses a local file at ./data/app.db
#   Production (Vercel): set BOTH from your Turso database.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
